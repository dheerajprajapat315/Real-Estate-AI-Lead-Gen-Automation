    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Clean text by removing extra spaces, special characters, and converting to lowercase\nconst item = $input.item.json;\n\n// Function to clean text\nfunction cleanText(text) {\n  if (typeof text !== 'string') {\n    return text;\n  }\n  \n  return text\n    .toLowerCase() // Convert to lowercase\n    .replace(/[^a-z0-9\\s]/g, ' ') // Remove special characters, keep alphanumeric and spaces\n    .replace(/\\s+/g, ' ') // Replace multiple spaces with single space\n    .trim(); // Remove leading/trailing spaces\n}\n\n// Clean all text fields in the item\nconst cleanedItem = {};\n\nfor (const key in item) {\n  if (typeof item[key] === 'string') {\n    cleanedItem[key] = cleanText(item[key]);\n  } else {\n    cleanedItem[key] = item[key];\n  }\n}\n\nreturn cleanedItem;"
      },
      "id": "ad6cfdaf-c884-4bbe-98fc-faa24a9ad9c0",
      "name": "Clean Text1",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        720,
        -64
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst output = [];\n\nfor (const item of items) {\n\n  try {\n\n    // AI JSON clean\n    let aiText = item.json.output.replace(/```json|```/g, \"\").trim();\n    const parsedData = JSON.parse(aiText);\n\n    // Extract fields\n    let budgetRaw = parsedData.budget_range || \"not sure\";\n    let budgetLower = budgetRaw.toLowerCase();\n\n    let urgencyRaw = (parsedData.urgency_level || \"low\").toLowerCase().trim();\n\n    // 🔥 USA Budget Based Urgency Override\n\n    if (budgetLower.includes(\"$2m\")) {\n\n      urgencyRaw = \"high\";\n\n    }\n\n    else if (budgetLower.includes(\"$1.2m\")) {\n\n      if (urgencyRaw === \"low\") urgencyRaw = \"medium\";\n\n    }\n\n    else if (budgetLower.includes(\"$800k\")) {\n\n      if (urgencyRaw === \"low\") urgencyRaw = \"medium\";\n\n    }\n\n    // City Clean\n    const finalCity =\n      item.json.city ||\n      parsedData.location ||\n      \"Not specified\";\n\n    // Property clean\n    const propertyType =\n      parsedData.property_type ||\n      \"Not specified\";\n\n    output.push({\n\n      json: {\n\n        intent: \"buyer\",\n\n        location: finalCity,\n\n        urgency: urgencyRaw,\n\n        property: propertyType,\n\n        budget_range: budgetRaw,\n\n        // Flags\n        is_high_urgency: urgencyRaw === \"high\",\n\n        is_medium_urgency: urgencyRaw === \"medium\",\n\n        is_buyer: true\n\n      }\n\n    });\n\n  }\n\n  catch (e) {\n\n    output.push({\n\n      json: {\n\n        error: \"AI response parsing failed\",\n\n        raw_output: item.json.output\n\n      }\n\n    });\n\n  }\n\n}\n\nreturn output;"
      },

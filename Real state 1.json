    {
      "parameters": {
        "jsCode": "const items = $input.all(); \nconst result = [];\n\nconst today = new Date();\nconst formattedDate =\ntoday.getDate().toString().padStart(2,'0') + '-' +\n(today.getMonth()+1).toString().padStart(2,'0') + '-' +\ntoday.getFullYear();\n\nconst data = items[0].json; \nlet score = 0;\n\nconst budget = (data.budget_range || \"\").toLowerCase().trim();\nconst urgency = (data.urgency || \"low\").toLowerCase().trim();\nconst property = (data.property || \"\").toLowerCase().trim();\nconst city = (data.location || \"\").toLowerCase().trim();\n\n\n// 💰 USA Budget Scoring\n\nif (budget.includes('$2m')) score += 45;\n\nelse if (budget.includes('$1.2m')) score += 40;\n\nelse if (budget.includes('$800k')) score += 30;\n\nelse if (budget.includes('$500k')) score += 20;\n\nelse if (budget.includes('below $500k')) score += 10;\n\nelse score += 10;\n\n\n// 📍 Location Scoring (High demand US markets)\n\nif (\ncity.includes('new york') ||\ncity.includes('manhattan') ||\ncity.includes('los angeles') ||\ncity.includes('san francisco')\n) score += 30;\n\nelse if (\ncity.includes('miami') ||\ncity.includes('austin') ||\ncity.includes('dallas') ||\ncity.includes('san diego')\n) score += 25;\n\nelse if (\ncity.includes('phoenix') ||\ncity.includes('seattle') ||\ncity.includes('denver')\n) score += 20;\n\nelse score += 10;\n\n\n// 🏠 Property Type Scoring\n\nif (property.includes('Single Family Home')) score += 20;\n\nelse if (property.includes('Townhouse')) score += 18;\n\nelse if (property.includes('Condo ') || property.includes('Apartment')) score += 15;\n\nelse if (property.includes('Commercial Property')) score += 12;\n\nelse score += 5;\n\n\n// 🚀 Urgency Scoring\n\nif (urgency === 'high') score += 15;\n\nelse if (urgency === 'medium') score += 10;\n\nelse score += 5;\n\n\n// 🔥 Lead Category Logic\n\nlet category = \"COLD\";\nlet priority = \"LOW\";\n\nif (score >= 85) {\n\ncategory = \"HOT\";\npriority = \"HIGH\";\n\n}\n\nelse if (score >= 60) {\n\ncategory = \"WARM\";\npriority = \"MEDIUM\";\n\n}\n\nelse {\n\ncategory = \"COLD\";\npriority = \"LOW\";\n\n}\n\n\n// Output\n\nresult.push({\n  json: {\n    ...data,\n    lead_score: score,\n    lead_category: category,\n    priority: priority,\n    submission_date: formattedDate\n  }\n});\n\nreturn result;"
      },
